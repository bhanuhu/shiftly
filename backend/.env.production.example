APP_NAME=SHIFTLY
ENVIRONMENT=production
DEBUG=false

# Supabase/Neon/etc can give postgresql:// or postgres:// URLs.
# The backend automatically converts them to postgresql+asyncpg:// at runtime.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# Upstash Redis example:
# REDIS_URL=rediss://default:PASSWORD@HOST.upstash.io:6379
REDIS_URL=rediss://default:PASSWORD@HOST:6379

JWT_SECRET_KEY=replace-with-a-random-64-character-secret
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# Leave empty in production once real SMS is connected.
OTP_DEV_OVERRIDE=
OTP_TTL_SECONDS=300
OTP_LENGTH=6

ADMIN_LOGIN=admin@shiftly.in
ADMIN_PASSWORD=replace-with-a-strong-admin-password
ADMIN_PHONE=+910000000000
ADMIN_NAME=SHIFTLY Admin

# Add your deployed admin URL and any local URLs you still use.
CORS_ORIGINS=https://your-shiftly-admin.vercel.app,http://localhost:3000

RATE_LIMIT_DEFAULT=100/minute
S3_BUCKET_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
CLOUDINARY_URL=
